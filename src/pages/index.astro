---
import Layout from '../layouts/Layout.astro';

const games = [
  {
    id: 'neon-blitz',
    title: 'Neon Blitz',
    description: 'Fast-paced arcade action. Dodge, collect, survive.',
    accent: '#F43F5E',
    accentDark: '#BE123C',
    accentLight: '#FFF1F2',
    status: 'playable'
  },
  {
    id: 'cosmic-drifter',
    title: 'Cosmic Drifter',
    description: 'Navigate the void. Minimalist space survival.',
    accent: '#0EA5E9',
    accentDark: '#0369A1',
    accentLight: '#F0F9FF',
    status: 'coming-soon'
  },
  {
    id: 'pixel-dungeon',
    title: 'Pixel Dungeon',
    description: 'Roguelike adventures in retro style.',
    accent: '#A855F7',
    accentDark: '#7E22CE',
    accentLight: '#FAF5FF',
    status: 'coming-soon'
  }
];
---

<Layout title="Games | shvnk.in">
  <div class="container">
    <header class="header">
      <div class="brand">
        <span class="brand-label">shvnk.in</span>
        <span class="brand-sep">/</span>
        <h1 class="brand-title">games</h1>
      </div>
      <p class="tagline">Click to play. No downloads.</p>
    </header>

    <main class="games-grid">
      {games.map((game, index) => (
        <a 
          href={game.status === 'playable' ? `/games/${game.id}` : '#'} 
          class={`game-card ${game.status}`}
          style={`--accent: ${game.accent}; --accent-dark: ${game.accentDark}; --accent-light: ${game.accentLight}; --delay: ${index * 120}ms`}
          data-game-id={game.id}
        >
          <div class="game-visual" transition:name={`game-visual-${game.id}`}>
            <div class="visual-pattern"></div>
            <div class="visual-shine"></div>
            <div class="visual-icon" transition:name={`game-icon-${game.id}`}>
              {game.status === 'playable' ? (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              ) : (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              )}
            </div>
          </div>
          <div class="game-info">
            <h2 class="game-title">{game.title}</h2>
            <p class="game-desc">{game.description}</p>
            <span class="game-status">
              {game.status === 'playable' ? (
                <span class="status-playable">
                  <span class="status-dot"></span>
                  Play Now
                </span>
              ) : (
                <span class="status-soon">Coming Soon</span>
              )}
            </span>
          </div>
        </a>
      ))}
    </main>

    <footer class="footer">
      <a href="https://shvnk.in" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="back-arrow">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        <span>Back to shvnk.in</span>
      </a>
    </footer>
  </div>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .header {
    margin-bottom: 4rem;
    animation: fadeIn 0.6s var(--ease-out-expo) forwards;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .brand-label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .brand-sep {
    color: var(--color-border);
    font-size: 1.25rem;
  }

  .brand-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .tagline {
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    flex: 1;
  }

  /* ---- Card ---- */
  .game-card {
    display: block;
    background: var(--accent);
    border-radius: 1.25rem;
    overflow: hidden;
    animation: slideUp 0.7s var(--ease-out-expo) var(--delay) forwards;
    opacity: 0;
    transform: translateY(24px);
    cursor: pointer;
    transition: transform 0.4s var(--ease-out-expo), 
                box-shadow 0.4s var(--ease-out-expo);
    box-shadow: 
      0 2px 8px -2px color-mix(in srgb, var(--accent) 25%, transparent),
      0 8px 24px -8px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .game-card:hover:not(.coming-soon) {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 
      0 8px 20px -4px color-mix(in srgb, var(--accent) 35%, transparent),
      0 20px 44px -12px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .game-card:active:not(.coming-soon) {
    transform: translateY(-2px) scale(0.99);
    transition-duration: 0.1s;
  }

  .game-card.coming-soon {
    cursor: default;
    opacity: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .game-card.coming-soon:hover {
    box-shadow: none;
  }

  /* ---- Visual area ---- */
  .game-visual {
    aspect-ratio: 16/9;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--accent) 100%, black 0%) 0%,
      var(--accent-dark) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .game-card.coming-soon .game-visual {
    background: linear-gradient(160deg, var(--accent-light) 0%, var(--color-surface) 100%);
  }

  .visual-pattern {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(255,255,255, 0.12) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .visual-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.2) 50%, transparent 60%);
    opacity: 0;
    transform: translateX(-100%);
    pointer-events: none;
  }

  .game-card:hover:not(.coming-soon) .visual-shine {
    animation: shine 0.8s var(--ease-out-expo);
  }

  @keyframes shine {
    0% { transform: translateX(-100%); opacity: 1; }
    100% { transform: translateX(100%); opacity: 0; }
  }

  .visual-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.4s var(--ease-out-expo);
    position: relative;
    z-index: 1;
  }

  .playable .visual-icon {
    animation: float 3s ease-in-out infinite;
  }

  .game-card:hover:not(.coming-soon) .visual-icon {
    background: rgba(255, 255, 255, 0.35);
    transform: scale(1.1);
  }

  .game-card.coming-soon .visual-icon {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    opacity: 0.6;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* ---- Info area ---- */
  .game-info {
    padding: 1.25rem 1.5rem 1.5rem;
    background: white;
  }

  .game-card.coming-soon .game-info {
    background: var(--color-surface);
  }

  .game-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.375rem;
    transition: color 0.25s var(--ease-out-expo);
  }

  .game-card:hover:not(.coming-soon) .game-title {
    color: var(--accent-dark);
  }

  .game-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .game-status {
    display: inline-block;
  }

  .status-playable {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-dark);
    background: var(--accent-light);
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
    transition: all 0.25s var(--ease-out-expo);
  }

  .game-card:hover:not(.coming-soon) .status-playable {
    background: var(--accent);
    color: white;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .game-card:hover:not(.coming-soon) .status-dot {
    background: white;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-soon {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  /* ---- Footer ---- */
  .footer {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    animation: fadeIn 0.6s var(--ease-out-expo) 0.4s forwards;
    opacity: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color 0.25s var(--ease-out-expo);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .back-arrow {
    transition: transform 0.3s var(--ease-out-expo);
  }

  .back-link:hover .back-arrow {
    transform: translateX(-3px);
  }

  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
