</style>

<script>
  import '../../scripts/game3d/main.ts';

  const controlButtons = document.querySelectorAll<HTMLElement>('[data-code]');
  const moveStick = document.getElementById('move-stick');
  const moveStickThumb = document.getElementById('move-stick-thumb');
  const interactButton = document.getElementById('mobile-use-btn');
  const lookZone = document.getElementById('look-zone');
  const missionShell = document.getElementById('mission-shell');
  const missionFab = document.getElementById('mission-fab');
  const startBtn = document.getElementById('start-btn');
  const resumeBtn = document.getElementById('resume-btn');

  const emitMove = (code: string, pressed: boolean) => {
    document.dispatchEvent(new CustomEvent('game3d:input', {
      detail: { code, pressed }
    }));
  };

  const emitLook = (deltaX: number, deltaY: number) => {
    document.dispatchEvent(new CustomEvent('game3d:look', {
      detail: { deltaX, deltaY }
    }));
  };

  const emitInteract = () => {
    document.dispatchEvent(new CustomEvent('game3d:interact'));
  };

  const emitAxis = (x: number, y: number) => {
    document.dispatchEvent(new CustomEvent('game3d:axis', {
      detail: { x, y }
    }));
  };

  const bindHoldControl = (button: HTMLElement, code: string) => {
    const press = (event: Event) => {
      event.preventDefault();
      emitMove(code, true);
    };
    const release = (event: Event) => {
      event.preventDefault();
      emitMove(code, false);
    };

    button.addEventListener('touchstart', press, { passive: false });
    button.addEventListener('touchend', release, { passive: false });
    button.addEventListener('touchcancel', release, { passive: false });
    button.addEventListener('mousedown', press);
    button.addEventListener('mouseup', release);
    button.addEventListener('mouseleave', release);
  };

  controlButtons.forEach((button) => {
    const code = button.dataset.code;
    if (!code) return;
    bindHoldControl(button, code);
  });

  if (moveStick && moveStickThumb) {
    let activePointerId: number | null = null;
    const radius = 58;

    const setThumb = (x: number, y: number) => {
      moveStickThumb.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
    };

    const updateStick = (event: PointerEvent) => {
      const rect = moveStick.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      let dx = event.clientX - centerX;
      let dy = event.clientY - centerY;

      const distance = Math.hypot(dx, dy);
      if (distance > radius) {
        const ratio = radius / distance;
        dx *= ratio;
        dy *= ratio;
      }

      setThumb(dx, dy);

      const nx = Math.max(-1, Math.min(1, dx / radius));
      const ny = Math.max(-1, Math.min(1, -dy / radius));
      emitAxis(nx, ny);
    };

    moveStick.addEventListener('pointerdown', (event) => {
      event.preventDefault();
      activePointerId = event.pointerId;
      (moveStick as HTMLElement).setPointerCapture(event.pointerId);
      updateStick(event);
    });

    moveStick.addEventListener('pointermove', (event) => {
      if (activePointerId !== event.pointerId) return;
      updateStick(event);
    });

    const releaseStick = (event: PointerEvent) => {
      if (activePointerId !== event.pointerId) return;
      activePointerId = null;
      setThumb(0, 0);
      emitAxis(0, 0);
    };

    moveStick.addEventListener('pointerup', releaseStick);
    moveStick.addEventListener('pointercancel', releaseStick);
    moveStick.addEventListener('pointerleave', releaseStick);
  }

  interactButton?.addEventListener('touchstart', (event) => {
    event.preventDefault();
    emitInteract();
  }, { passive: false });
  interactButton?.addEventListener('click', emitInteract);

  if (lookZone) {
    let activePointerId: number | null = null;
    let lastX = 0;
    let lastY = 0;

    lookZone.addEventListener('pointerdown', (event) => {
      event.preventDefault();
      activePointerId = event.pointerId;
      lastX = event.clientX;
      lastY = event.clientY;
      lookZone.classList.add('active');
      (lookZone as HTMLElement).setPointerCapture(event.pointerId);
    });

    lookZone.addEventListener('pointermove', (event) => {
      if (activePointerId !== event.pointerId) return;
      const dx = event.clientX - lastX;
      const dy = event.clientY - lastY;
      lastX = event.clientX;
      lastY = event.clientY;
      emitLook(dx * 1.55, dy * 1.4);
    });

    const releaseLook = (event: PointerEvent) => {
      if (activePointerId !== event.pointerId) return;
      activePointerId = null;
      lookZone.classList.remove('active');
    };

    lookZone.addEventListener('pointerup', releaseLook);
    lookZone.addEventListener('pointercancel', releaseLook);
    lookZone.addEventListener('pointerleave', releaseLook);
  }

  const requestImmersiveMode = async () => {
    const gameContainer = document.querySelector('.game-container') as HTMLElement | null;
    if (!gameContainer) return;

    if (!document.fullscreenElement && gameContainer.requestFullscreen) {
      try {
        await gameContainer.requestFullscreen();
      } catch {
        // Ignore browser-level fullscreen rejections.
      }
    }

    const orientation = (screen as any).orientation;
    if (orientation?.lock) {
      try {
        await orientation.lock('landscape');
      } catch {
        // Orientation lock is browser/device dependent.
      }
    }
  };

  startBtn?.addEventListener('click', requestImmersiveMode);
  resumeBtn?.addEventListener('click', requestImmersiveMode);

  if (window.matchMedia('(max-width: 900px)').matches) {
    missionShell?.classList.remove('open');
    missionFab?.setAttribute('aria-expanded', 'false');
  }

  missionFab?.addEventListener('click', (event) => {
    event.stopPropagation();
    if (!missionShell) return;
    const opened = missionShell.classList.toggle('open');
    missionFab.setAttribute('aria-expanded', String(opened));
  });

  document.addEventListener('pointerdown', (event) => {
    if (!missionShell || !missionFab) return;
    if (!window.matchMedia('(max-width: 900px)').matches) return;
    if (!missionShell.classList.contains('open')) return;

    const target = event.target as Node | null;
    if (target && missionShell.contains(target)) return;

    missionShell.classList.remove('open');
    missionFab.setAttribute('aria-expanded', 'false');
  });
</script>
