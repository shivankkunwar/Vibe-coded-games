---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { gameId: 'game-2' } },
    { params: { gameId: 'game-3' } },
  ];
}

const { gameId } = Astro.params;

const games: Record<string, { title: string; color: string }> = {
  'game-2': { title: 'Coming Soon', color: '#06B6D4' },
  'game-3': { title: 'Coming Soon', color: '#A855F7' },
};

const game = games[gameId || ''];

if (!game) {
  return Astro.redirect('/');
}
---

<Layout title={`${game.title} | shvnk.in`}>
  <div class="game-container">
    <header class="game-header">
      <a href="/" class="back-btn">
        <span class="back-icon">←</span>
        <span class="back-text">Exit</span>
      </a>
      <h1 class="game-title">{game.title}</h1>
      <div class="header-right">
        <button class="fullscreen-btn" id="fullscreen-btn" aria-label="Toggle fullscreen">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
          </svg>
        </button>
        <div class="score-display">
          <span class="score-label">Score</span>
          <span class="score-value" id="score">0</span>
        </div>
      </div>
    </header>
    
    <div class="game-wrapper" id="game-wrapper" transition:name={`game-visual-${gameId}`}>
      <div class="game-placeholder">
        <div class="placeholder-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="placeholder-title">{game.title}</h3>
        <p class="placeholder-subtitle">Coming Soon</p>
        <p class="placeholder-desc">This game is under development. Check back soon!</p>
      </div>
    </div>
    
    <div class="controls-hint">
      <span>Arrow Keys / WASD to move</span>
      <span class="hint-sep">•</span>
      <span>Explore the lab, find clues</span>
    </div>

    <div class="d-pad" id="d-pad">
      <button class="d-btn d-up" data-dir="up" aria-label="Move up">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-8 8h5v8h6v-8h5z"/></svg>
      </button>
      <button class="d-btn d-left" data-dir="left" aria-label="Move left">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4 12l8-8v5h8v6h-8v5z"/></svg>
      </button>
      <button class="d-btn d-right" data-dir="right" aria-label="Move right">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20 12l-8 8v-5h-8v-6h8v-5z"/></svg>
      </button>
      <button class="d-btn d-down" data-dir="down" aria-label="Move down">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 20l8-8h-5v-8h-6v8h-5z"/></svg>
      </button>
    </div>

    <div class="rotate-prompt" id="rotate-prompt">
      <div class="rotate-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="4" width="20" height="16" rx="2" transform="rotate(90 12 12)"/>
          <path d="M12 8v8M8 12l4-4 4 4"/>
        </svg>
      </div>
      <p>Rotate your device to landscape</p>
    </div>
  </div>
</Layout>

<script>
  // Fullscreen toggle
  const fullscreenBtn = document.getElementById('fullscreen-btn');
  const gameWrapper = document.getElementById('game-wrapper');

  fullscreenBtn?.addEventListener('click', async () => {
    if (!document.fullscreenElement) {
      await gameWrapper?.requestFullscreen();
    } else {
      await document.exitFullscreen();
    }
  });

  document.addEventListener('fullscreenchange', () => {
    if (fullscreenBtn) {
      const icon = fullscreenBtn.querySelector('svg');
      if (icon) {
        if (document.fullscreenElement) {
          icon.innerHTML = '<path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/>';
        } else {
          icon.innerHTML = '<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>';
        }
      }
    }
  });

  // D-pad controls
  const dPad = document.getElementById('d-pad');
  const dButtons = dPad?.querySelectorAll('.d-btn');
  const virtualKeys: Record<string, string> = {
    up: 'UP',
    down: 'DOWN',
    left: 'LEFT',
    right: 'RIGHT'
  };

  function simulateKey(dir: string, pressed: boolean) {
    const event = new KeyboardEvent(pressed ? 'keydown' : 'keyup', {
      key: virtualKeys[dir],
      code: `Arrow${virtualKeys[dir]}`,
      bubbles: true
    });
    document.dispatchEvent(event);
  }

  dButtons?.forEach(btn => {
    const dir = btn.getAttribute('data-dir');
    if (!dir) return;

    btn.addEventListener('touchstart', (e) => {
      e.preventDefault();
      simulateKey(dir, true);
      (btn as HTMLElement).style.transform = 'scale(0.9)';
    });

    btn.addEventListener('touchend', (e) => {
      e.preventDefault();
      simulateKey(dir, false);
      (btn as HTMLElement).style.transform = '';
    });

    btn.addEventListener('mousedown', () => simulateKey(dir, true));
    btn.addEventListener('mouseup', () => simulateKey(dir, false));
    btn.addEventListener('mouseleave', () => simulateKey(dir, false));
  });

  // Landscape detection
  const rotatePrompt = document.getElementById('rotate-prompt');

  function checkOrientation() {
    if (rotatePrompt) {
      rotatePrompt.style.display = window.innerWidth < 768 && window.innerHeight > window.innerWidth ? 'flex' : 'none';
    }
  }

  window.addEventListener('resize', checkOrientation);
  checkOrientation();
</script>

<style>
  .game-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--color-bg);
  }

  .game-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    width: 100%;
    margin: 0 auto 1.5rem;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: all 0.3s var(--ease-out-expo);
  }

  .back-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateX(-4px);
  }

  .back-btn:active {
    transform: translateX(-2px) scale(0.98);
  }

  .back-icon {
    font-size: 1rem;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .back-btn:hover .back-icon {
    transform: translateX(-2px);
  }

  .game-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .fullscreen-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
  }

  .fullscreen-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .fullscreen-btn:active {
    transform: scale(0.95);
  }

  .score-display {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .score-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .score-value {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .game-wrapper {
    position: relative;
    max-width: 800px;
    width: 100%;
    aspect-ratio: 4/3;
    margin: 0 auto;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: linear-gradient(135deg, #1a1a2e 0%, #0a0a0a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-placeholder {
    text-align: center;
    color: white;
    padding: 2rem;
  }

  .placeholder-icon {
    margin-bottom: 1.5rem;
    opacity: 0.6;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.05); }
  }

  .placeholder-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--color-accent, #06B6D4);
  }

  .placeholder-subtitle {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .placeholder-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.4);
    max-width: 280px;
    margin: 0 auto;
  }

  .game-canvas {
    width: 100%;
    height: 100%;
  }

  .game-canvas canvas {
    width: 100% !important;
    height: 100% !important;
  }

  .game-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    transform: scale(0.95);
  }

  .game-overlay.visible {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .overlay-content {
    text-align: center;
    transform: translateY(10px);
    transition: transform 0.4s var(--ease-out-expo);
  }

  .game-overlay.visible .overlay-content {
    transform: translateY(0);
  }

  .overlay-title {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .overlay-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .start-btn {
    padding: 1rem 3rem;
    background: var(--color-accent);
    border: none;
    border-radius: 0.5rem;
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
  }

  .start-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 30px -10px var(--color-accent);
  }

  .controls-hint {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .confetti-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .confetto {
    position: absolute;
    width: 10px;
    height: 10px;
    background: var(--c);
    top: 50%;
    left: 50%;
    animation: confetti-fall var(--d) ease-out forwards;
    transform: translate(-50%, -50%) rotate(var(--r));
  }

  @keyframes confetti-fall {
    to {
      transform: translate(calc(-50% + var(--x)), 200px) rotate(calc(var(--r) + 720deg));
      opacity: 0;
    }
  }

  /* D-Pad for mobile */
  .d-pad {
    display: none;
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    width: 140px;
    height: 140px;
    z-index: 100;
  }

  .d-btn {
    position: absolute;
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .d-btn:active {
    transform: scale(0.9);
    background: rgba(255, 255, 255, 0.3);
  }

  .d-up { top: 0; left: 50%; transform: translateX(-50%); }
  .d-down { bottom: 0; left: 50%; transform: translateX(-50%); }
  .d-left { top: 50%; left: 0; transform: translateY(-50%); }
  .d-right { top: 50%; right: 0; transform: translateY(-50%); }

  /* Rotate prompt */
  .rotate-prompt {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.95);
    z-index: 200;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    color: white;
  }

  .rotate-icon {
    animation: rotate-hint 1.5s ease-in-out infinite;
  }

  @keyframes rotate-hint {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(90deg); }
  }

  .rotate-prompt p {
    font-size: 1rem;
    opacity: 0.8;
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .d-pad {
      display: grid;
      grid-template-areas:
        ". up ."
        "left . right"
        ". down .";
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 4px;
    }

    .d-up { grid-area: up; }
    .d-down { grid-area: down; }
    .d-left { grid-area: left; }
    .d-right { grid-area: right; }

    .game-wrapper {
      touch-action: none;
    }

    .controls-hint {
      display: none;
    }
  }

  @media (max-width: 768px) and (orientation: portrait) {
    .rotate-prompt {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    .game-container {
      padding: 1rem;
      padding-bottom: calc(1rem + env(safe-area-inset-bottom));
    }

    .game-header {
      margin-bottom: 1rem;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .back-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
    }

    .game-title {
      font-size: 1.25rem;
      order: 3;
      width: 100%;
      text-align: center;
      padding-top: 0.5rem;
      border-top: 1px solid var(--color-border);
      margin-top: 0.5rem;
    }

    .header-right {
      gap: 0.75rem;
    }

    .fullscreen-btn {
      width: 2.25rem;
      height: 2.25rem;
    }

    .score-value {
      font-size: 1.25rem;
    }
  }

  /* Fullscreen mode */
  .game-container:fullscreen {
    padding: 0;
    background: #0a0a0a;
  }

  .game-container:fullscreen .game-header {
    display: none;
  }

  .game-container:fullscreen .game-wrapper {
    max-width: none;
    width: 100vw;
    height: 100vh;
    aspect-ratio: unset;
    border-radius: 0;
    border: none;
  }

  .game-container:fullscreen .controls-hint {
    display: none;
  }

  @media (max-width: 768px) {
    .game-container:fullscreen .d-pad {
      display: grid;
    }
  }
</style>
